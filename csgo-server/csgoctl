#!/usr/bin/env bash
set -euo pipefail

SESSION="csgo"
WORKDIR="/home/csgo/Steam/steamapps/common/Counter-Strike Global Offensive Beta - Dedicated Server"

CMD="./srcds_run \
-game csgo \
-console \
-usercon \
-port 27015 \
-tickrate 128 \
-maxplayers_override 20 \
+game_type 0 \
+game_mode 1 \
+mapgroup mg_active \
+map de_dust2 \
+sv_lan 1 \
+sv_setsteamaccount 0"

case "${1:-}" in
  start)
    sudo -iu csgo tmux new-session -d -s "$SESSION" -c "$WORKDIR" "$CMD"
    ;;
  stop)
    sudo -iu csgo tmux kill-session -t "$SESSION"
    ;;
  attach)
    sudo -iu csgo tmux attach -t "$SESSION"
    ;;
  status)
    sudo -iu csgo tmux ls
    ;;
  restart)
    $0 stop || true
    sleep 1
    $0 start
    ;;
  *)
    echo "Usage: csgoctl {start|stop|restart|attach|status}" >&2
    exit 2
    ;;
esac
